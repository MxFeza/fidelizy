# =============================================================================
# Fidelizy / Izou - Template variables d'environnement
# =============================================================================
# Copie ce fichier en `.env.local` puis remplis les valeurs.
# Ne committe JAMAIS .env.local (il est dans .gitignore).
# Toutes ces variables doivent etre dupliquees dans Vercel (Production + Preview).
# =============================================================================


# -----------------------------------------------------------------------------
# Supabase (obligatoire)
# -----------------------------------------------------------------------------
# Dashboard Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Cle service-role : NE JAMAIS exposer cote client. Server-only.
SUPABASE_SERVICE_ROLE_KEY=


# -----------------------------------------------------------------------------
# App URL (lib/config.ts)
# -----------------------------------------------------------------------------
# En local : http://localhost:3000
# En prod  : https://fidelizy.app (Vercel injecte VERCEL_URL automatiquement en preview)
NEXT_PUBLIC_APP_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# Upstash Redis (rate limiting - lib/ratelimit.ts)
# -----------------------------------------------------------------------------
# Console Upstash > Database > REST API
KV_REST_API_URL=
KV_REST_API_TOKEN=


# -----------------------------------------------------------------------------
# Web Push / VAPID (lib/push/sendPush.ts)
# -----------------------------------------------------------------------------
# Generation : npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@fidelizy.app


# -----------------------------------------------------------------------------
# Apple Wallet (lib/wallet/generatePass.ts)
# -----------------------------------------------------------------------------
# Apple Developer > Identifiers > Pass Type IDs
APPLE_PASS_TYPE_ID=pass.app.fidelizy.loyalty
APPLE_TEAM_ID=

# Certificats encodes en base64 (cat cert.pem | base64 -w 0)
APPLE_PASS_CERT_B64=
APPLE_PASS_KEY_B64=
APPLE_WWDR_CERT_B64=

# Secret HMAC pour signer les tokens d'auth Wallet (32+ chars random)
WALLET_AUTH_SECRET=


# -----------------------------------------------------------------------------
# Notion (feedback DB - app/api/feedback/route.ts)
# -----------------------------------------------------------------------------
# https://www.notion.so/my-integrations
NOTION_API_KEY=
NOTION_FEEDBACK_DB_ID=


# -----------------------------------------------------------------------------
# Cron jobs (app/api/cron/*)
# -----------------------------------------------------------------------------
# Secret partage avec Vercel Cron - genere un secret random 32+ chars
# Vercel Dashboard > Project > Settings > Environment Variables (CRON_SECRET)
CRON_SECRET=


# -----------------------------------------------------------------------------
# Sentry (project: ebella/fidelizy on de.sentry.io)
# -----------------------------------------------------------------------------
# DSN is public-safe (intended to be exposed client-side). The auth token
# is server-only and only required for source map uploads at build time.
NEXT_PUBLIC_SENTRY_DSN=https://a58bc757b4b2cc4fb5e38679694853bc@o4511305612394496.ingest.de.sentry.io/4511332402724944
SENTRY_ORG=ebella
SENTRY_PROJECT=fidelizy

# Required for source map uploads in CI/Vercel build only (optional locally) :
# Sentry > Settings > Auth Tokens > Create new (scopes: project:releases, org:read)
# SENTRY_AUTH_TOKEN=
