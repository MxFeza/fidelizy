{
  "name": "fidelizy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npx playwright test",
    "test:unit": "vitest",
    "test:unit:run": "vitest run",
    "prepare": "husky",
    "export-for-llm": "repomix --output .tmp/repomix-bundle.md --style markdown --ignore \"**/*.lock,.next,public/**/*.{png,jpg,jpeg,webp,gif,ico,svg},supabase/migrations/.archive,docs/sessions,docs/figma,coverage,playwright-report,.tmp\"",
    "audit:auth-rls": "repomix --output .tmp/audit-auth-rls.md --style markdown --include \"app/api/auth/**,middleware.ts,lib/supabase/**,lib/auth/**,supabase/migrations/**,.env.example,next.config.ts\" --ignore \"**/*.lock,.next,supabase/migrations/.archive/**\"",
    "audit:api": "repomix --output .tmp/audit-api-validation.md --style markdown --include \"app/api/**/route.ts,lib/services/**/*.schemas.ts,lib/ratelimit.ts,lib/error/**\" --ignore \"**/*.lock,.next\"",
    "audit:services": "repomix --output .tmp/audit-services.md --style markdown --include \"lib/services/**/*.ts\" --ignore \"**/*.lock,**/__tests__/**\"",
    "audit:wallet": "repomix --output .tmp/audit-wallet-observability.md --style markdown --include \"lib/wallet/**,sentry.*.config.ts,instrumentation.ts,app/api/wallet/**\" --ignore \"**/*.lock\"",
    "audit:all": "npm run audit:auth-rls && npm run audit:api && npm run audit:services && npm run audit:wallet"
  },
  "dependencies": {
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@react-stately/utils": "^3.12.1",
    "@resvg/resvg-js": "^2.6.2",
    "@sentry/nextjs": "^10.55.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.98.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/qrcode": "^1.5.6",
    "@untitledui/file-icons": "^0.0.9",
    "@untitledui/icons": "^0.0.22",
    "@untitledui/react": "github:untitleduico/react",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "framer-motion": "^12.40.0",
    "html5-qrcode": "^2.3.8",
    "jspdf": "^4.2.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.577.0",
    "next": "16.2.7",
    "next-themes": "^0.4.6",
    "node-forge": "^1.3.3",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "19.2.7",
    "react-aria-components": "^1.18.0",
    "react-dom": "19.2.7",
    "react-easy-crop": "^5.5.7",
    "recharts": "^3.7.0",
    "satori": "^0.26.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "tailwindcss-react-aria-components": "^2.1.1",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/node-forge": "^1.3.14",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^4.1.8",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.8",
    "repomix": "^1.14.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
